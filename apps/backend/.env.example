# Environment Configuration
# Copy this file to .env and fill in the actual values

# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:yourpassword@localhost:5432/radio_inventar

# API token guarding all non-public endpoints (REQUIRED, >= 32 chars)
API_TOKEN=change-me-to-a-long-random-token-min-32-chars
# Session cookie secret for the admin login (REQUIRED, >= 32 chars)
SESSION_SECRET=change-me-to-a-long-random-secret-min-32

# CORS allowed origins (comma-separated, required in production)
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

# Story 6.5: PDF Print Template with QR Code
# Public app URL embedded in QR code for offline fallback
# Production: Must be valid HTTPS URL
# Development: Defaults to http://localhost:5173 if not set
PUBLIC_APP_URL=https://radio-inventar.example.com

# radio-admin integration — REQUIRED in production.
# radio-admin is now the master for BOTH devices AND loans (the local Loan table
# was dropped); without it every device/loan/history/borrower request returns 503.
# RADIO_ADMIN_URL is always required. Pick ONE auth mode:
#   (a) static api-token  : set RADIO_ADMIN_API_TOKEN (>= 32 chars) — a token
#       minted in radio-admin's admin UI. Simplest; no Pocket ID needed.
#   (b) OAuth2 client_credentials (Pocket ID): set RADIO_ADMIN_ISSUER_URL +
#       RADIO_ADMIN_CLIENT_ID + RADIO_ADMIN_CLIENT_SECRET (all three together).
# RADIO_ADMIN_CACHE_TTL_MS  device-list cache TTL in ms (default 30000)
RADIO_ADMIN_URL=https://radio-admin.example.com
# --- auth mode (a): static token ---
RADIO_ADMIN_API_TOKEN=
# --- auth mode (b): client_credentials ---
RADIO_ADMIN_ISSUER_URL=https://id.example.com
RADIO_ADMIN_CLIENT_ID=radio-inventar
RADIO_ADMIN_CLIENT_SECRET=
RADIO_ADMIN_CACHE_TTL_MS=30000
